generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions  Session[]
  accounts  Account[]
  projects  Project[]
  brandKits BrandKit[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@map("account")
  @@index([userId])
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@unique([identifier, value])
  @@map("verification")
  @@index([identifier])
}

model Project {
  id          String    @id @default(cuid())
  /** Opaque token for public share URLs (never use raw project id in public links). */
  shareToken  String    @unique @default(cuid())
  prompt      String    @default("Untitled Animation")
  videoCode   String
  duration    Int       @default(10)
  aspectRatio String    @default("16:9")
  videoType   String    @default("general")
  scenes      Json?
  musicMood   String?
  downloadUrl String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandKitId  String?
  brandKit    BrandKit? @relation(fields: [brandKitId], references: [id])

  @@map("project")
  @@index([userId])
}

model BrandKit {
  id            String   @id @default(cuid())
  name          String   @default("My Brand")
  sourceUrl     String?

  // Visual identity
  logoUrl       String?
  colors        Json     // { primary, secondary, accent, background, text }
  brandPalette  Json?    // string[] up to 8 colors
  fonts         Json?    // { heading, body }

  // Content extracted
  headline      String?
  subheadline   String?
  features      Json?    // [{ title, description }]
  cta           String?
  tone          String?
  style         String?

  // Images from site
  images        Json?    // [{ url, alt, context }]

  testimonials  Json?    // [{ quote, author, role }]
  integrations  Json?    // [{ name, logoUrl }]
  pricingCues     Json?    // string[] or { label, detail }[]

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects      Project[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("brand_kit")
  @@index([userId])
}
