# Copy to ".env" or ".env.local" and fill in values.

# PostgreSQL connection string (required for Prisma / saving projects)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Google AI — required for /api/generate-video (motion code generation)
GEMINI_API_KEY=""

# Signs the login session cookie (long random string, min 16 chars). Not a third-party API key.
SESSION_SECRET="change-me-to-a-long-random-string-at-least-16-chars"

# Single allowed login (plain env password — fine for a personal / demo deployment)
APP_LOGIN_EMAIL="you@example.com"
APP_LOGIN_PASSWORD="choose-a-strong-password"

# Display name stored on the User row when you sign in
APP_USER_NAME="Owner"

# Optional: canonical site URL (helps redirects / links in production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
