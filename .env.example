# Copy to ".env" or ".env.local" and fill in values.

# PostgreSQL connection string (required for Prisma / saving projects)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# TLS: verify server certificates (recommended). Set to "false" only for local dev with self-signed DB.
DATABASE_SSL_REJECT_UNAUTHORIZED="true"

# Google AI — required for /api/generate-video (motion code generation)
GEMINI_API_KEY=""

# Signs the login session cookie (long random string, min 16 chars). Not a third-party API key.
SESSION_SECRET="change-me-to-a-long-random-string-at-least-16-chars"

# Single allowed login (plain env password — fine for a personal / demo deployment)
APP_LOGIN_EMAIL="you@example.com"
APP_LOGIN_PASSWORD="choose-a-strong-password"

# Display name stored on the User row when you sign in
APP_USER_NAME="Owner"

# Optional: canonical site URL (helps redirects / links in production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# God templates (JSON → TemplateRegistry). Default on unless set to "false".
USE_GOD_TEMPLATES="true"

# Optional: POST JSON { videoCode, duration, aspectRatio } to this URL for server-side MP4 (Remotion Lambda / custom worker). If unset, downloads use in-browser WebM recording.
REMOTION_RENDER_WEBHOOK_URL=""
# Optional: HMAC-SHA256 hex secret; when set, outbound webhook requests include header X-Motion-Signature over the raw JSON body for your worker to verify.
REMOTION_RENDER_WEBHOOK_SECRET=""
